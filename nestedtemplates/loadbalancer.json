{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "publicIpId": {
            "type": "string"
        },
        "loadBalancerName": {
            "type": "string"
        },
        "numberOfInstances": {
            "type": "int"
        },
        "location": {
            "type": "string"
        },
        "publicIPAddressSku": {
            "type": "string",
            "defaultValue": "Standard",
            "allowedValues": [
                "Basic",
                "Standard"
            ],
            "metadata": {
                "description": "SKU of the Public IP Address"
            }
        },
        "outboundRuleName": {
            "type": "string",
            "defaultValue": "loadBalancerBackEnd",
            "metadata": {
                "description": "Name of the outbound rule"
            }
        },
        "outboundRuleProtocol": {
            "type": "string",
            "defaultValue": "All",
            "allowedValues": [
                "Tcp",
                "Udp",
                "All"
            ],
            "metadata": {
                "description": "Protocol for the outbound rule"
            }
        }
    },
    "variables": {
        "lbFrontendName": "loadBalancerFrontEnd",
        "lbBackendName": "loadBalancerBackEnd",
        "inboundNatNameUI": "Webadmin-Sophos-Firewall",
        "inboundNatNameSSH": "SSH-Sophos-Firewall",
        "probeName": "Probe-Webadmin-On-4444",
        "lbID": "[resourceId('Microsoft.Network/loadBalancers',parameters('loadBalancerName'))]",
        "lbFrontendID": "[resourceId('Microsoft.Network/loadBalancers/frontendIPConfigurations',parameters('loadBalancerName'), variables('lbFrontendName'))]",
        "lbBackendID": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools',parameters('loadBalancerName'), variables('lbBackendName'))]",
        "lbProbeID": "[resourceId('Microsoft.Network/loadBalancers/probes',parameters('loadBalancerName'), variables('probeName'))]",
        "inboundNatIDPrefixUI": "[resourceId('Microsoft.Network/loadBalancers/inboundNatRules', parameters('loadBalancerName'), variables('inboundNatNameUI'))]",
        "inboundNatIDPrefixSSH": "[resourceId('Microsoft.Network/loadBalancers/inboundNatRules', parameters('loadBalancerName'), variables('inboundNatNameSSH'))]",
        "outboundRuleID": "[resourceId('Microsoft.Network/loadBalancers/outboundRules', parameters('loadBalancerName'), parameters('outboundRuleName'))]"
    },
    "resources": [
        {
            "apiVersion": "2022-07-01",
            "name": "[parameters('loadBalancerName')]",
            "type": "Microsoft.Network/loadBalancers",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('publicIPAddressSku')]"
            },
            "properties": {
                "frontendIPConfigurations": [
                    {
                        "name": "[variables('lbFrontendName')]",
                        "properties": {
                            "publicIPAddress": {
                                "id": "[parameters('publicIpId')]"
                            }
                        }
                    }
                ],
                "backendAddressPools": [
                    {
                        "name": "[variables('lbBackendName')]"
                    }
                ],
                "loadBalancingRules": [
                    {
                        "name": "HTTP",
                        "properties": {
                            "frontendIPConfiguration": {
                                "id": "[variables('lbFrontendID')]"
                            },
                            "frontendPort": 80,
                            "backendPort": 80,
                            "enableFloatingIP": false,
                            "idleTimeoutInMinutes": 4,
                            "protocol": "Tcp",
                            "loadDistribution": "SourceIP",
                            "backendAddressPool": {
                                "id": "[variables('lbBackendID')]"
                            },
                            "probe": {
                                "id": "[variables('lbProbeID')]"
                            },
                            "disableOutboundSnat": true
                        }
                    }
                ],
                "probes": [
                    {
                        "name": "[variables('probeName')]",
                        "properties": {
                            "protocol": "Tcp",
                            "port": 4444,
                            "intervalInSeconds": 5,
                            "numberOfProbes": 2
                        }
                    }
                ],
                "outboundRules": [
                    {
                        "name": "[parameters('outboundRuleName')]",
                        "properties": {
                            "allocatedOutboundPorts": 31968,
                            "protocol": "[parameters('outboundRuleProtocol')]",
                            "enableTcpReset": true,
                            "idleTimeoutInMinutes": 4,
                            "backendAddressPool": {
                                "id": "[variables('lbBackendID')]"
                            },
                            "frontendIPConfigurations": [
                                {
                                    "id": "[variables('lbFrontendID')]"
                                }
                            ]
                        }
                    }
                ]
            }
        },
        {
            "apiVersion": "2022-07-01",
            "name": "[concat(parameters('loadBalancerName'), '/', variables('inboundNatNameUI'))]",
            "type": "Microsoft.Network/loadBalancers/inboundNatRules",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[concat('Microsoft.Network/loadBalancers/', parameters('loadBalancerName'))]"
            ],
            "properties": {
                "frontendIPConfiguration": {
                    "id": "[variables('lbFrontendID')]"
                },
                "backendAddressPool": {
                    "id": "[variables('lbBackendID')]"
                },
                "protocol": "Tcp",
                "frontendPortRangeStart": 4444,
                "frontendPortRangeEnd": 4445,
                "backendPort": 4444,
                "enableFloatingIP": false,
                "enableTcpReset": false,
                "idleTimeoutInMinutes": 4
            }
        },
        {
            "apiVersion": "2022-07-01",
            "name": "[concat(parameters('loadBalancerName'), '/', variables('inboundNatNameSSH'))]",
            "type": "Microsoft.Network/loadBalancers/inboundNatRules",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[concat('Microsoft.Network/loadBalancers/', parameters('loadBalancerName'))]"
            ],
            "properties": {
                "frontendIPConfiguration": {
                    "id": "[variables('lbFrontendID')]"
                },
                "backendAddressPool": {
                    "id": "[variables('lbBackendID')]"
                },
                "protocol": "Tcp",
                "frontendPortRangeStart": 2222,
                "frontendPortRangeEnd": 2223,
                "backendPort": 22,
                "enableFloatingIP": false,
                "enableTcpReset": false,
                "idleTimeoutInMinutes": 4
            }
        }
    ],
    "outputs": {
        "lbID": {
            "value": "[variables('lbID')]",
            "type": "string"
        },
        "lbFrontendID": {
            "value": "[variables('lbFrontendID')]",
            "type": "string"
        },
        "lbBackendID": {
            "value": "[variables('lbBackendID')]",
            "type": "string"
        },
        "inboundNatIDPrefixUI": {
            "value": "[variables('inboundNatIDPrefixUI')]",
            "type": "string"
        },
        "inboundNatIDPrefixSSH": {
            "value": "[variables('inboundNatIDPrefixSSH')]",
            "type": "string"
        },
        "outboundRuleID": {
            "value": "[variables('outboundRuleID')]",
            "type": "string"
        }
    }
}
